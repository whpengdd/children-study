# AI provider for scenario generation (claude|chunfeng). Default: claude
AI_PROVIDER=claude

# Claude provider (AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-xxx

# Chunfeng provider (AI_PROVIDER=chunfeng)
# OpenAI-compatible Responses API at https://chunfeng.mentalout.top/v1
OPENAI_API_KEY=sk-xxx
CHUNFENG_MODEL=gpt-5.1-codex-mini
CHUNFENG_REASONING_EFFORT=low
